{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git pull)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git fetch)",
      "Bash(git branch -d *)",
      "Bash(git branch -D *)",
      "Bash(git branch --set-upstream-to *)",
      "Bash(cd * && git add *)",
      "Bash(cd * && git commit *)",
      "Bash(cd * && git checkout *)",
      "Bash(cd * && git pull)",
      "Bash(cd * && git pull *)",
      "Bash(cd * && git merge *)",
      "Bash(cd * && git push *)",
      "Bash(cd * && git fetch *)",
      "Bash(cd * && git fetch)",
      "Bash(cd * && git branch *)",
      "Bash(cd * && git branch -d *)",
      "Bash(cd * && git branch -D *)",
      "Bash(cd * && git branch --set-upstream-to *)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm test)",
      "Bash(npm run test:watch)",
      "Bash(npm install)",
      "Bash(cd * && npm run build *)",
      "Bash(cd * && npm install *)",
      "Bash(cd * && npm test *)",
      "Bash(supabase migration list)",
      "Bash(mkdir *)",
      "Bash(rm .claude/*)"
    ],
    "deny": []
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"continue\": false, \"stopReason\": \"Worktrees are disabled for this project. Work directly on main or a named branch per CLAUDE.md.\"}'"
          }
        ]
      }
    ]
  }
}
